# WrzDJ Environment Configuration
# Copy to .env and customize as needed

# =============================================================================
# Environment (development or production)
# =============================================================================
ENV=development

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql+psycopg://wrzdj:wrzdj@localhost:5432/wrzdj

# =============================================================================
# Authentication
# =============================================================================
# IMPORTANT: Change this in production! Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# =============================================================================
# Spotify API (https://developer.spotify.com/dashboard)
# =============================================================================
SPOTIFY_CLIENT_ID=your-client-id
SPOTIFY_CLIENT_SECRET=your-client-secret

# =============================================================================
# Tidal API (https://developer.tidal.com/dashboard)
# =============================================================================
TIDAL_CLIENT_ID=your-client-id
TIDAL_CLIENT_SECRET=your-client-secret
TIDAL_REDIRECT_URI=your-sites-oauth-callback

# =============================================================================
# Beatport API v4 (server-side OAuth2 login flow)
# =============================================================================
# Option A: Apply for official partner access at https://partnerportal.beatport.com
# Option B: Use the public client_id from Beatport's Swagger UI docs at
#           https://api.beatport.com/v4/docs/ (no client_secret needed)
#
# The backend authenticates with Beatport using the user's Beatport credentials
# (username/password → session cookies → auth code → tokens). No browser popup needed.
#
# BEATPORT_CLIENT_SECRET is optional — public OAuth clients work without it.
# BEATPORT_CLIENT_ID=your-client-id
# BEATPORT_CLIENT_SECRET=
# BEATPORT_REDIRECT_URI=https://api.beatport.com/v4/auth/o/post-message/
#
# Auth base URL — controls which Beatport Identity Service is used:
#   Partner Portal (default): https://account.beatport.com
#   Public Swagger client:    https://api.beatport.com/v4/auth
# BEATPORT_AUTH_BASE_URL=https://account.beatport.com

# =============================================================================
# StageLinQ Bridge
# =============================================================================
# Shared secret used by the bridge to authenticate with the backend.
# Generate with: openssl rand -hex 32
BRIDGE_API_KEY=change-me-in-production

# =============================================================================
# CORS Origins
# =============================================================================
# Comma-separated list of allowed origins, or "*" for all (dev only)
#
# Local development:
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
#
# Production with subdomains:
# CORS_ORIGINS=https://app.yourdomain.com

# =============================================================================
# Public URL
# =============================================================================
# Used for QR codes and shareable links (should be your frontend URL)
# Leave empty to auto-detect from browser's current origin
#
# Local development:
PUBLIC_URL=http://localhost:3000
#
# Production:
# PUBLIC_URL=https://app.yourdomain.com

# =============================================================================
# File Uploads
# =============================================================================
# Directory for uploaded files (banner images).
# Defaults to server/uploads/ relative to project root when empty.
# In Docker, set to /app/uploads (mapped to a named volume).
# UPLOADS_DIR=
# MAX_BANNER_SIZE_MB=5

# =============================================================================
# Rate Limiting & Security
# =============================================================================
# These are auto-enabled in production and disabled in development.
# Override if needed:
#
# RATE_LIMIT_ENABLED=true
# LOCKOUT_ENABLED=true
#
# Rate limits (requests per minute per IP):
# LOGIN_RATE_LIMIT_PER_MINUTE=5
# SEARCH_RATE_LIMIT_PER_MINUTE=30
# REQUEST_RATE_LIMIT_PER_MINUTE=10

# =============================================================================
# Admin User (created on first startup)
# =============================================================================
# Creates admin user on first startup if no users exist.
# This user gets the admin role with full access to the admin dashboard.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=your-secure-password

# =============================================================================
# Cloudflare Turnstile (CAPTCHA for self-registration)
# =============================================================================
# Get keys at: https://dash.cloudflare.com/?to=/:account/turnstile
# TURNSTILE_SITE_KEY=your-site-key
# TURNSTILE_SECRET_KEY=your-secret-key

# =============================================================================
# LLM / AI providers
# =============================================================================
# As of v2026.05.24, LLM credentials are managed per-DJ via the gateway
# (admin: /admin/ai, DJ: /settings/ai). On first deploy, ANTHROPIC_API_KEY
# is migrated into a system-default "anthropic_apikey" connector (assigned
# to the first admin user for management, set as the org-wide default).
# After the migration runs you can remove ANTHROPIC_API_KEY from this file
# — a follow-up release will delete the env-var fallback path entirely
# (tracked under the "AI Engine Back-end Redesign" milestone).
#
# ANTHROPIC_API_KEY=your-anthropic-key       # DEPRECATED — migrated to connector
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_MAX_TOKENS=1024
# ANTHROPIC_TIMEOUT_SECONDS=15

# =============================================================================
# Frontend (Next.js)
# =============================================================================
# API URL for the dashboard to connect to
#
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:8000
#
# Production:
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
